= form_with(model: donor, local: true) do |form|
  - if donor.errors.any?
    #error_explanation
      %h2
        = pluralize(donor.errors.count, "error")
        prohibited this donor from being saved:
      %ul
        - donor.errors.full_messages.each do |message|
          %li= message
  .form-control
    = form.text_field :name, class:'form-control mt-4', placeholder:'Nome Completo'
  
    = form.text_field :phone, class:'form-control my-2', placeholder:'Telefone'
  
    = form.text_field :email, class:'form-control my-2', placeholder:'Email'

    = form.select(:donation, @donations_options_for_select, {}, {class: "chosen-select form-control my-2"})
  
    = form.text_area :message, class:'form-control my-2', placeholder:'Descrição'
    .actions
      = form.submit "Confirmar", id: "confirmar", class:'col-lg-12 mt-2 mb-4 btn btn-lg btn-login'