<p id="notice"><%= notice %></p>

<h1>Requesters</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Identify</th>
      <th>Cpf</th>
      <th>Street</th>
      <th>Number</th>
      <th>Sector</th>
      <th>City</th>
      <th>Zip</th>
      <th>Referency point</th>
      <th>Residence</th>
      <th>Fenced plot</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @requesters.each do |requester| %>
      <tr>
        <td><%= requester.name %></td>
        <td><%= requester.email %></td>
        <td><%= requester.phone %></td>
        <td><%= requester.identify %></td>
        <td><%= requester.cpf %></td>
        <td><%= requester.street %></td>
        <td><%= requester.number %></td>
        <td><%= requester.sector %></td>
        <td><%= requester.city %></td>
        <td><%= requester.zip %></td>
        <td><%= requester.referency_point %></td>
        <td><%= requester.residence %></td>
        <td><%= requester.fenced_plot %></td>
        <td><%= link_to 'Show', requester %></td>
        <td><%= link_to 'Edit', edit_requester_path(requester) %></td>
        <td><%= link_to 'Destroy', requester, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Requester', new_requester_path %>
