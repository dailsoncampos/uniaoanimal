  </div>

  <div class="field">
    <%= form.label :color %>
    <%= form.number_field :color %>
  </div>

  <div class="field">
    <%= form.label :genre %>
    <%= form.number_field :genre %>
  </div>

  <div class="field">
    <%= form.label :breed %>
    <%= form.text_field :breed %>
  </div>

  <div class="field">
    <%= form.label :size %>
    <%= form.number_field :size %>
  </div>

  <div class="field">
