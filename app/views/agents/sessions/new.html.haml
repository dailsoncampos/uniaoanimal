.container
  %h1.h3.mb-3.font-weight-normal Entrar
  = image_tag "logo-uniao-animal.png", class: "mb-4", alt:"Logo da ONG", height: "72", src: "logo-uniao-animal.png", width: "72"
  = form_for(resource, class: "form-signin", as: resource_name, url: session_path(resource_name)) do |f|
    .field
      = f.label :email
      %br
      = f.email_field :email, autofocus: true, autocomplete: "email"
    .field
      = f.label :password
      %br
      = f.password_field :password, autocomplete: "current-password"
    - if devise_mapping.rememberable?
      .field
        = f.check_box :remember_me
        = f.label :remember_me
    .actions
      = f.submit "Confirmar"
  = render "agents/shared/links"